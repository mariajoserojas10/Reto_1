#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/gpio.h"
#include "driver/adc.h"
#include "driver/ledc.h"

// 7 Segmentos
#define SEG_A  25
#define SEG_B  33
#define SEG_C  19
#define SEG_D  22
#define SEG_E  21
#define SEG_F  32
#define SEG_G  23

// Dígitos
#define DIG_1  26
#define DIG_2  27
#define DIG_3  14

// LEDS
#define LED_VERDE  17
#define LED_ROJO    4

// Botones
#define BTN_DER   5
#define BTN_IZQ  16

// Potenciómetro GPIO35 
#define POT_CH   ADC1_CHANNEL_7

// Puente H
#define MOTOR_HS_IZQ  18
#define MOTOR_HS_DER  13
#define MOTOR_LS_IZQ  15
#define MOTOR_LS_DER  12

// PWM
#define PWM_FREQ_HZ    2000
#define PWM_RESOLUTION LEDC_TIMER_10_BIT
#define PWM_TIMER      LEDC_TIMER_0
#define PWM_MODE       LEDC_HIGH_SPEED_MODE
#define PWM_CH_IZQ     LEDC_CHANNEL_0
#define PWM_CH_DER     LEDC_CHANNEL_1

// Protección inversión
#define BRAKE_STEP_MS   15
#define BRAKE_DECREMENT 80
#define DEAD_TIME_MS    300

typedef enum { DIR_DERECHA, DIR_IZQUIERDA } direccion_t;

static direccion_t dir_actual  = DIR_DERECHA;
static int         duty_actual = 0;

// DISPLAY 

void clear_segments(void){
    gpio_set_level(SEG_A,0); gpio_set_level(SEG_B,0); gpio_set_level(SEG_C,0);
    gpio_set_level(SEG_D,0); gpio_set_level(SEG_E,0); gpio_set_level(SEG_F,0);
    gpio_set_level(SEG_G,0);
}

void display_digit(int n){
    clear_segments();
    switch(n){
        case 0: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1);
                gpio_set_level(SEG_D,1);gpio_set_level(SEG_E,1);gpio_set_level(SEG_F,1); break;
        case 1: gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1); break;
        case 2: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_D,1);
                gpio_set_level(SEG_E,1);gpio_set_level(SEG_G,1); break;
        case 3: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1);
                gpio_set_level(SEG_D,1);gpio_set_level(SEG_G,1); break;
        case 4: gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1);
                gpio_set_level(SEG_F,1);gpio_set_level(SEG_G,1); break;
        case 5: gpio_set_level(SEG_A,1);gpio_set_level(SEG_C,1);gpio_set_level(SEG_D,1);
                gpio_set_level(SEG_F,1);gpio_set_level(SEG_G,1); break;
        case 6: gpio_set_level(SEG_A,1);gpio_set_level(SEG_C,1);gpio_set_level(SEG_D,1);
                gpio_set_level(SEG_E,1);gpio_set_level(SEG_F,1);gpio_set_level(SEG_G,1); break;
        case 7: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1); break;
        case 8: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1);
                gpio_set_level(SEG_D,1);gpio_set_level(SEG_E,1);gpio_set_level(SEG_F,1);
                gpio_set_level(SEG_G,1); break;
        case 9: gpio_set_level(SEG_A,1);gpio_set_level(SEG_B,1);gpio_set_level(SEG_C,1);
                gpio_set_level(SEG_D,1);gpio_set_level(SEG_F,1);gpio_set_level(SEG_G,1); break;
    }
}

void mostrar_numero(int numero){
    if(numero < 0)   numero = 0;
    if(numero > 100) numero = 100;

    int centenas = numero / 100;
    int decenas  = (numero / 10) % 10;
    int unidades = numero % 10;

    clear_segments();
    gpio_set_level(DIG_1,1); gpio_set_level(DIG_2,0); gpio_set_level(DIG_3,0);
    display_digit(unidades);
    vTaskDelay(pdMS_TO_TICKS(5));

    clear_segments();
    gpio_set_level(DIG_1,0); gpio_set_level(DIG_2,1); gpio_set_level(DIG_3,0);
    display_digit(decenas);
    vTaskDelay(pdMS_TO_TICKS(5));

    clear_segments();
    gpio_set_level(DIG_1,0); gpio_set_level(DIG_2,0); gpio_set_level(DIG_3,1);
    display_digit(centenas);
    vTaskDelay(pdMS_TO_TICKS(5));
}

// MOTOR

void puente_h_off(void){
    ledc_set_duty(PWM_MODE, PWM_CH_IZQ, 0); ledc_update_duty(PWM_MODE, PWM_CH_IZQ);
    ledc_set_duty(PWM_MODE, PWM_CH_DER, 0); ledc_update_duty(PWM_MODE, PWM_CH_DER);
    vTaskDelay(pdMS_TO_TICKS(1));
    gpio_set_level(MOTOR_HS_IZQ, 1);
    gpio_set_level(MOTOR_HS_DER, 1);
    duty_actual = 0;
}

void motor_brake_ramp(void){
    int d = duty_actual;
    while(d > 0){
        d -= BRAKE_DECREMENT;
        if(d < 0) d = 0;
        if(dir_actual == DIR_DERECHA){
            ledc_set_duty(PWM_MODE, PWM_CH_IZQ, d);
            ledc_update_duty(PWM_MODE, PWM_CH_IZQ);
        } else {
            ledc_set_duty(PWM_MODE, PWM_CH_DER, d);
            ledc_update_duty(PWM_MODE, PWM_CH_DER);
        }
        vTaskDelay(pdMS_TO_TICKS(BRAKE_STEP_MS));
    }
    puente_h_off();
}

void motor_apply(direccion_t dir, int duty){
    // Si duty es muy bajo apagar completamente
    if(duty < 10){
        puente_h_off();
        return;
    }

    if(dir == DIR_DERECHA){
        gpio_set_level(MOTOR_HS_IZQ, 1);
        ledc_set_duty(PWM_MODE, PWM_CH_DER, 0); ledc_update_duty(PWM_MODE, PWM_CH_DER);
        vTaskDelay(pdMS_TO_TICKS(1));
        gpio_set_level(MOTOR_HS_DER, 0);
        ledc_set_duty(PWM_MODE, PWM_CH_IZQ, duty); ledc_update_duty(PWM_MODE, PWM_CH_IZQ);
    } else {
        gpio_set_level(MOTOR_HS_DER, 1);
        ledc_set_duty(PWM_MODE, PWM_CH_IZQ, 0); ledc_update_duty(PWM_MODE, PWM_CH_IZQ);
        vTaskDelay(pdMS_TO_TICKS(1));
        gpio_set_level(MOTOR_HS_IZQ, 0);
        ledc_set_duty(PWM_MODE, PWM_CH_DER, duty); ledc_update_duty(PWM_MODE, PWM_CH_DER);
    }
    duty_actual = duty;
    dir_actual  = dir;
}

void motor_cambiar_dir(direccion_t nueva){
    if(nueva == dir_actual) return;
    motor_brake_ramp();
    vTaskDelay(pdMS_TO_TICKS(DEAD_TIME_MS));
    dir_actual = nueva;
}

// PWM INIT 

void pwm_init(void){
    ledc_timer_config_t timer = {
        .speed_mode      = PWM_MODE,
        .timer_num       = PWM_TIMER,
        .duty_resolution = PWM_RESOLUTION,
        .freq_hz         = PWM_FREQ_HZ,
        .clk_cfg         = LEDC_AUTO_CLK
    };
    ledc_timer_config(&timer);

    ledc_channel_config_t ch0 = {
        .speed_mode = PWM_MODE, .channel  = PWM_CH_IZQ,
        .timer_sel  = PWM_TIMER,.gpio_num = MOTOR_LS_IZQ,
        .duty = 0, .hpoint = 0
    };
    ledc_channel_config(&ch0);

    ledc_channel_config_t ch1 = {
        .speed_mode = PWM_MODE, .channel  = PWM_CH_DER,
        .timer_sel  = PWM_TIMER,.gpio_num = MOTOR_LS_DER,
        .duty = 0, .hpoint = 0
    };
    ledc_channel_config(&ch1);
}

void app_main(void){

    gpio_config_t out_cfg = {
        .pin_bit_mask =
            (1ULL<<SEG_A)|(1ULL<<SEG_B)|(1ULL<<SEG_C)|
            (1ULL<<SEG_D)|(1ULL<<SEG_E)|(1ULL<<SEG_F)|(1ULL<<SEG_G)|
            (1ULL<<DIG_1)|(1ULL<<DIG_2)|(1ULL<<DIG_3)|
            (1ULL<<LED_VERDE)|(1ULL<<LED_ROJO)|
            (1ULL<<MOTOR_HS_IZQ)|(1ULL<<MOTOR_HS_DER),
        .mode         = GPIO_MODE_OUTPUT,
        .pull_up_en   = GPIO_PULLUP_DISABLE,
        .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type    = GPIO_INTR_DISABLE
    };
    gpio_config(&out_cfg);

    gpio_config_t in_cfg = {
        .pin_bit_mask = (1ULL<<BTN_DER)|(1ULL<<BTN_IZQ),
        .mode         = GPIO_MODE_INPUT,
        .pull_up_en   = GPIO_PULLUP_ENABLE,
        .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type    = GPIO_INTR_DISABLE
    };
    gpio_config(&in_cfg);

    adc1_config_width(ADC_WIDTH_BIT_12);
    adc1_config_channel_atten(POT_CH, ADC_ATTEN_DB_11);

    pwm_init();
    puente_h_off();

    clear_segments();
    gpio_set_level(DIG_1,0); gpio_set_level(DIG_2,0); gpio_set_level(DIG_3,0);

    dir_actual = DIR_DERECHA;
    gpio_set_level(LED_VERDE, 1);
    gpio_set_level(LED_ROJO,  0);

    bool btn_der_prev = false;
    bool btn_izq_prev = false;

    while(1){
        int raw        = adc1_get_raw(POT_CH);
        int porcentaje = (raw * 100) / 4095;
        int duty_nuevo = (raw * 1023) / 4095;

        bool btn_der_now = (gpio_get_level(BTN_DER) == 0);
        bool btn_izq_now = (gpio_get_level(BTN_IZQ) == 0);

        if(btn_der_now && !btn_der_prev){
            motor_cambiar_dir(DIR_DERECHA);
            gpio_set_level(LED_VERDE, 1);
            gpio_set_level(LED_ROJO,  0);
        }

        if(btn_izq_now && !btn_izq_prev){
            motor_cambiar_dir(DIR_IZQUIERDA);
            gpio_set_level(LED_VERDE, 0);
            gpio_set_level(LED_ROJO,  1);
        }

        btn_der_prev = btn_der_now;
        btn_izq_prev = btn_izq_now;

        motor_apply(dir_actual, duty_nuevo);
        mostrar_numero(porcentaje);
    }
}
